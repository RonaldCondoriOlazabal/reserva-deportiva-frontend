{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Disponibilidad (up)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up", "legendFormat": "{{job}} ({{instance}})" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Requests por segundo",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by (job) (rate(http_server_requests_seconds_count[1m]))", "legendFormat": "{{job}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Errores HTTP 5xx",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by (job) (rate(http_server_requests_seconds_count{status=~\"5..\"}[1m]))", "legendFormat": "{{job}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } }
    },
    {
      "title": "Memoria JVM usada",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by (job) (jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "{{job}}" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "CPU del sistema",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "avg by (job) (system_cpu_usage)", "legendFormat": "{{job}}" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 } }
    },
    {
      "title": "Circuit Breaker (reservas)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "resilience4j_circuitbreaker_state{name=\"reservasDetalle\"}", "legendFormat": "{{instance}} - {{state}}" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Logs por servicio (Loki)",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "{service=~\"auth|canchas|horarios|reservas|pago\"}", "legendFormat": "" }],
      "options": { "showTime": true, "showLabels": true, "sortOrder": "Descending" }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["microservicios", "reservas", "unidad-2"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Microservicios - Reservas Deportivas",
  "uid": "reservas-ms-dashboard",
  "version": 1
}
